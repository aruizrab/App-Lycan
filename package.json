    "dompurify": "^3.3.1",
    "html2pdf.js": "^0.12.1",
    "lucide-vue-next": "^0.555.0",
    "marked": "^15.0.12",
    "pinia": "^3.0.4",
    "tiptap-markdown": "^0.9.0",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
