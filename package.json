{
  "name": "app-lycan",
  "version": "1.2.1",
  "description": "A privacy-first, AI-powered CV and cover letter builder that runs entirely in your browser.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "keywords": [
    "vue",
    "vite",
    "cv-builder",
    "resume",
    "cover-letter",
    "ai",
    "privacy-first",
    "offline-first",
    "tailwindcss"
  ],
  "scripts": {
