    "jsdom": "^27.4.0",
    "lint-staged": "^16.3.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.2",
    "tailwindcss": "^4.1.17",
    "vite": "^7.2.4",
